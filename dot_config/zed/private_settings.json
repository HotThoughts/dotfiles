{
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "right"
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "tabs": {
    "file_icons": true,
  },
  "context_servers": {
    "mcp-server-github": {
      "enabled": true,
      "settings": {},
    },
    "mcp-server-context7": {
      "enabled": true,
      "settings": {},
    },
  },
  "ssh_connections": [
    {
      "host": "raspberryzero",
      "username": "pi",
      "upload_binary_over_ssh": true,
      "projects": [
        {
          "paths": ["/home/pi"],
        },
      ],
    },
    {
      "host": "raspberry",
      "username": "pi",
      "upload_binary_over_ssh": true,
      "projects": [
        {
          "paths": ["/home/pi/infra"],
        },
      ],
    },
  ],
  "edit_predictions": {
    "provider": "copilot",
    "mode": "eager",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null,
      "enterprise_uri": null,
    },
    "enabled_in_text_threads": false,
  },
  "ui_font_family": "SF Pro",
  "ui_font_size": 16,
  "icon_theme": {
    "mode": "dark",
    "light": "Symbols",
    "dark": "Symbols"
  },
  "git_panel": {
    "dock": "right",
  },
  "agent": {
    "dock": "left",
    "tool_permissions": {
      "default": "allow",
    },
    "default_open_ai_model": "gpt-5.1",
    "profiles": {
      "write": {
        "name": "Write",
        "tools": {
          "search_web": true,
          "open": true,
          "copy_path": true,
          "create_directory": true,
          "create_file": true,
          "delete_path": true,
          "diagnostics": true,
          "edit_file": true,
          "fetch": true,
          "list_directory": true,
          "move_path": true,
          "now": true,
          "find_path": true,
          "read_file": true,
          "grep": true,
          "terminal": true,
          "thinking": true,
        },
        "enable_all_context_servers": true,
        "context_servers": {
          "mcp-server-context7": {
            "tools": {
              "resolve-library-id": true,
              "get-library-docs": true,
            },
          },
        },
      },
    },
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-4.1",
    },
    "default_profile": "write",
    "default_model": {
      "enable_thinking": true,
      "effort": "high",
      "provider": "copilot_chat",
      "model": "gemini-3-flash-preview",
    },
    "model_parameters": [],
  },
  "base_keymap": "VSCode",
  "buffer_font_size": 16,
  "buffer_font_family": "Operator Mono Lig",
  "buffer_font_fallbacks": ["Hack Nerd Font"],
  "theme": {
    "mode": "light",
    "light": "Catppuccin Latte",
    "dark": "Halcyon",
  },
  "languages": {
    "YAML": {
      "format_on_save": "off",
      "formatter": "language_server",
    },
  },
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "always",
    "use_smartcase_find": true,
    "use_multiline_find": true,
    "toggle_relative_line_numbers": true,
  },
  "experimental.theme_overrides": {
    "players": [
      {
        "cursor": "#ff5f00",
        "background": "#ff5f00ff",
        "selection": "#ff5f003d",
      },
    ],
  },
  "terminal": {
    "blinking": "on",
    "font_family": "Operator Mono Lig",
  },
  "autosave": "on_focus_change",
  "inline_code_actions": true,
  "symbols.folders.associations": {
    "infra": "folder-purple-code",
    "static": "folder-constants",
    "backup": "folder-gray",
    "cluster": "folder-config",
    "dev": "folder-green",
    "staging": "folder-yellow",
    "production": "folder-red",
  },
  "lsp": {
    "yaml-language-server": {
      "settings": {
        "yaml": {
          "keyOrdering": false,
          "schemas": {
            "https://json.schemastore.org/bower.json": ["/*"],
            "../relative/path/schema.json": ["/config*.yaml"],
          },
        },
      },
    },
  },
}
