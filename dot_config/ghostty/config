# Fonts
font-size = 15
font-family = "Operator Mono Lig"
font-style = Light
font-style-bold = Book
font-style-italic = Light Italic
font-style-bold-italic = Book Italic
font-thicken = true

# Styles
theme = Tokyonight Moon

macos-titlebar-style = hidden


background-opacity = 0.9
background-blur-radius = 50

fullscreen = false
macos-non-native-fullscreen = padded-notch

window-padding-x = 10
window-padding-y = 10
window-padding-balance = true
window-save-state = always
mouse-hide-while-typing = true

cursor-color = #ff5f00
cursor-opacity = 0.8
cursor-style = block
cursor-style-blink = true


custom-shader = shaders/cursor_blaze.glsl

# Quick terminal
quick-terminal-position = top
quick-terminal-size = 50%
gtk-quick-terminal-layer = overlay

# Shall integration
shell-integration = fish
shell-integration-features = no-cursor,ssh-terminfo,ssh-env

# Keybinds
keybind = cmd+t=new_tab
keybind = cmd+n=text:\x1bN
keybind = cmd+enter=text:\x1bn
# keybind = global:ctrl+q=toggle_quick_terminal
keybind = cmd+p=toggle_command_palette
keybind = cmd+[=text:\x1bT
keybind = cmd+]=text:\x1bt
keybind = cmd+up=text:\x1b[1;3A
keybind = cmd+down=text:\x1b[1;3B
keybind = cmd+left=text:\x1b[1;3D
keybind = cmd+right=text:\x1b[1;3C

keybind = alt+left=unbind
keybind = alt+right=unbind
macos-option-as-alt = true
